# ─── Sistema de Leads V2 — Configuração ───────────────────────
# Copia este ficheiro para `.env` e preenche os valores.

# Identidade da agência (aparecem nos emails enviados)
SENDER_NAME="VV TRAFFIC DATA"
SENDER_EMAIL="wtrafficdataeu@gmail.com"
SENDER_COUNTRY_CODE="351"

# ─── Captação ─────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=""
APIFY_API_TOKEN=""

# ─── Enriquecimento ───────────────────────────────────────────
HUNTER_API_KEY=""
# Opcional: deixar vazio = usa só validação sintática+MX
ZEROBOUNCE_API_KEY=""

# ─── Disparo ──────────────────────────────────────────────────
BREVO_API_KEY=""

# WhatsApp — Modo A: Z-API (trial 7 dias)
# WhatsApp — Modo B: Evolution self-hosted (recomendado)
# Preencher conforme o provider que estás a usar.
WHATSAPP_PROVIDER="evolution"  # ou "zapi"

# Z-API
ZAPI_INSTANCE_ID=""
ZAPI_TOKEN=""
ZAPI_CLIENT_TOKEN=""

# Evolution API (self-hosted)
EVOLUTION_BASE_URL="http://localhost:8080"
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE="vvtraffic"

# ─── IA ───────────────────────────────────────────────────────
# Gemini 2.0 Flash (1M tokens/dia FREE) — recomendado
GEMINI_API_KEY=""
# Alternativa: Groq Llama 3.3 70B (14.400 req/dia FREE)
GROQ_API_KEY=""

# ─── App ──────────────────────────────────────────────────────
APP_HOST="127.0.0.1"
APP_PORT="8000"
APP_SECRET="muda-isto-para-uma-string-aleatoria-bem-grande"
APP_USERNAME="admin"
APP_PASSWORD="muda-isto"

# Base de dados (SQLite local por defeito)
DATABASE_URL="sqlite:///./data/leads.db"

# Webhook público (URL ngrok quando estiveres a desenvolver)
PUBLIC_WEBHOOK_BASE=""

# Logging
LOG_LEVEL="INFO"

# Limites anti-bloqueio
WHATSAPP_MAX_PER_DAY="50"
EMAIL_MAX_PER_DAY="100"
SEND_DELAY_MS="1500"

# Follow-up (dias)
FOLLOWUP_D1="0"
FOLLOWUP_D2="2"
FOLLOWUP_D3="4"
FOLLOWUP_D4="7"
FOLLOWUP_D5="10"
